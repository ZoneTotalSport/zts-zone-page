rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // userQuotas — gere cote worker via Admin SDK (bypass rules).
    // Pas d'acces direct depuis le client web.
    // ─────────────────────────────────────────────────────────
    match /userQuotas/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────
    // anonGenCount — compteur essais anonymes par fingerprint.
    // Create : count==1, fingerprint string, firstSeen=serverTimestamp.
    // Update : count strictement croissant, plafond 999, lastSeen=serverTimestamp.
    // Delete : interdit.
    // ─────────────────────────────────────────────────────────
    match /anonGenCount/{fingerprint} {
      allow read: if true;
      allow create: if request.resource.data.count == 1
                    && request.resource.data.fingerprint is string
                    && request.resource.data.firstSeen == request.time;
      allow update: if request.resource.data.count == resource.data.count + 1
                    && request.resource.data.count <= 999
                    && request.resource.data.lastSeen == request.time;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // conversionFunnel — append-only events.
    // Lecture/update/delete interdits cote client (analytics interne).
    // ─────────────────────────────────────────────────────────
    match /conversionFunnel/{eventId} {
      allow create: if request.resource.data.timestamp == request.time
                    && request.resource.data.event is string
                    && request.resource.data.source is string;
      allow read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Tout le reste : interdit par defaut.
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
